# Include machine specific info, ie:
# [user]
#	name = My Name
# 	email = my.name@work.com

[include]
    path = ~/.gitconfig.local

# Shared config
[alias]
	lol = log --graph --decorate --pretty=oneline --abbrev-commit
	lola = log --graph --decorate --pretty=oneline --abbrev-commit --all
[column]
	ui = auto
[branch]
	sort = -committerdate
[tag]
	sort = version:refname
[init]
	defaultBranch = main
[rerere]
	enabled = true
	autoupdate = true
[rebase]
	autoSquash = true
	autoStash = true
	updateRefs = true
[diff]
	algorithm = histogram
	colorMoved = plain
	mnemonicPrefix = true
	renames = true
[color]
	ui = auto
[core]
	excludesfile = /home/benjamin/.gitignore
	editor = vim
	whitespace = cr-at-eol
[push]
	default = simple
[merge]
	tool = meld
[github]
	user = bgturner
[pull]
	rebase = true
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[fetch]
	prune = true
